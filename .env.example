# Device File Transfer local configuration example
# The Go server automatically loads this file when it is named .env in the project root.
# Shell environment variables override values from .env.

SERVER_HOST=0.0.0.0
SERVER_PORT=8000
UPLOAD_DIR=uploads

# Change this before using the app on a real network.
ACCESS_TOKEN=change-this-token
AUTH_ENABLED=true

# Unit: MB. 0 means unlimited.
MAX_UPLOAD_SIZE_MB=500

# Set false to disable delete API even with a valid token.
ALLOW_DELETE=true

LOG_DIR=logs
